        function renderConfigUI() {
            // Default patterns
            const defRule = (filterRules || []).find(r => r.phoneNumber === 'DEFAULT');
            const defPatterns = defRule ? defRule.patterns || [] : [];
            const defHtml = defPatterns.map((p, i) =>
                `<div class="config-row">
                    <span class="pattern-text">${escHtml(p)}</span>
                    <button class="del-btn" onclick="removeDefaultPattern(${i})">✕</button>
                </div>`
            ).join('') || '<div style="color:var(--text-3);font-size:12px;padding:8px">No default patterns set</div>';
            document.getElementById('defaultPatternsList').innerHTML = defHtml;

            // Number-specific rules
            const numRules = (filterRules || []).filter(r => r.phoneNumber !== 'DEFAULT');
            const numHtml = numRules.map((r, i) =>
                `<div class="config-row">
                    <span class="phone-label">${escHtml(r.phoneNumber)}</span>
                    <span class="pattern-text">${(r.patterns||[]).map(escHtml).join(', ') || '(catch-all)'}</span>
                    <button class="del-btn" onclick="removeNumberRule(${i})">✕</button>
                </div>`
            ).join('') || '<div style="color:var(--text-3);font-size:12px;padding:8px">No number-specific rules</div>';
            document.getElementById('numberRulesList').innerHTML = numHtml;

            document.getElementById('cfgAutoDelete').value = autoDeleteMinutes;
        }

        function addDefaultPattern() {
            const inp = document.getElementById('newDefaultPattern');
            const val = inp.value.trim();
            if (!val) return;
            if (!Array.isArray(filterRules)) filterRules = [];
            let def = filterRules.find(r => r.phoneNumber === 'DEFAULT');
            if (!def) { def = { phoneNumber: 'DEFAULT', patterns: [] }; filterRules.push(def); }
            def.patterns.push(val);
            inp.value = '';
            renderConfigUI();
        }
        function removeDefaultPattern(idx) {
            const def = (filterRules || []).find(r => r.phoneNumber === 'DEFAULT');
            if (def && def.patterns) { def.patterns.splice(idx, 1); renderConfigUI(); }
        }
        function addNumberRule() {
            const phone = document.getElementById('newRulePhone').value.trim();
            if (!phone) return;
            const pat = document.getElementById('newRulePattern').value.trim();
            if (!Array.isArray(filterRules)) filterRules = [];
            const patterns = pat ? [pat] : [];
            // Check if rule for this phone already exists
            const existing = filterRules.find(r => r.phoneNumber === phone);
            if (existing) {
                if (pat) existing.patterns.push(pat);
            } else {
                // Insert before DEFAULT
                const defIdx = filterRules.findIndex(r => r.phoneNumber === 'DEFAULT');
                if (defIdx >= 0) filterRules.splice(defIdx, 0, { phoneNumber: phone, patterns });
                else filterRules.push({ phoneNumber: phone, patterns });
            }
            document.getElementById('newRulePhone').value = '';
            document.getElementById('newRulePattern').value = '';
            renderConfigUI();
        }
        function removeNumberRule(idx) {
            const numRules = (filterRules || []).filter(r => r.phoneNumber !== 'DEFAULT');
            if (idx >= 0 && idx < numRules.length) {
                const phone = numRules[idx].phoneNumber;
                filterRules = filterRules.filter(r => r.phoneNumber !== phone || r.phoneNumber === 'DEFAULT');
                // Re-add DEFAULT if it was accidentally removed
                renderConfigUI();
            }
        }

        async function saveConfig() {
            try {
                // Save filters
                await database.ref('filters').set(filterRules || []);

                // Save settings
                const mins = parseInt(document.getElementById('cfgAutoDelete').value) || 10;
                autoDeleteMinutes = mins;
                await database.ref('settings/auto_delete_minutes').set(mins);
                reapplyDeleteAt();

                // Re-extract codes with new filters
                allMessages.forEach(msg => {
                    msg.extractedCode = msg.extractedCode || extractCode(msg.message || msg.code, msg.sender, msg.recipient);
                });
                displayMessages();

                showNotification(`✅ Saved! ${(filterRules||[]).length} rules, auto-delete: ${mins} min`);
                closeConfig();
            } catch (e) {
                showNotification('❌ Save failed: ' + e.message);
            }
        }

        function escHtml(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

        // ═══════════════════════════════════════════════════════
        //  CODE EXTRACTION (client-side, mirrors server)
        // ═══════════════════════════════════════════════════════
        function extractCode(message, sender, recipient) {
            if (!message) return null;
            let patterns = [];

            for (const rule of (filterRules || [])) {
                if (rule.phoneNumber === 'DEFAULT') continue;
                const normSender = (sender || '').toUpperCase().replace(/[\s_-]/g, '');
                const normRule = rule.phoneNumber.toUpperCase().replace(/[\s_-]/g, '');
                const normRecipient = (recipient || '').toUpperCase().replace(/[\s_-]/g, '');
                if (normSender.includes(normRule) || normRule.includes(normSender) ||
                    normRecipient.includes(normRule) || normRule.includes(normRecipient)) {
                    patterns = rule.patterns; break;
                }
            }
            if (patterns.length === 0) {
                const def = (filterRules || []).find(r => r.phoneNumber === 'DEFAULT');
                if (def) patterns = def.patterns;
            }
            for (const pattern of (patterns || [])) {
                try {
                    const match = message.match(new RegExp(pattern, 'i'));
                    if (match && match[1]) { let code = match[1].trim(); return convertTextToNumber(code); }
                } catch (e) {}
            }
            return null;
        }

        function convertTextToNumber(text) {
            let result = text.toLowerCase();
            for (const [word, digit] of Object.entries(textToNum))
                result = result.replace(new RegExp('\\b' + word + '\\b', 'g'), digit);
            const digits = result.match(/\d+/g);
            return digits ? digits.join('') : text;
        }

