        // ═══════════════════════════════════════════════════════
        //  LOAD MESSAGES
        // ═══════════════════════════════════════════════════════
        function reapplyDeleteAt() {
            if (!allMessages.length) return;
            let changed = false;
            allMessages.forEach(msg => {
                if (msg.status === 'pending' && msg.arrivedAt) {
                    const nd = msg.arrivedAt + (autoDeleteMinutes * 60 * 1000);
                    if (msg.deleteAt !== nd) { msg.deleteAt = nd; changed = true; database.ref(`sms/${msg.id}`).update({ deleteAt: nd }); }
                }
            });
            if (changed) { pendingMessages = allMessages.filter(m => m.status === 'pending'); displayMessages(); }
        }

        const deleteAtStamped = new Set();
        function ensureDeleteAt(msg) {
            if (msg.arrivedAt && !msg.deleteAt) {
                msg.deleteAt = msg.arrivedAt + (autoDeleteMinutes * 60 * 1000);
                if (!deleteAtStamped.has(msg.id)) { deleteAtStamped.add(msg.id); database.ref(`sms/${msg.id}`).update({ deleteAt: msg.deleteAt }); }
            }
            return msg;
        }

        function loadMessages() {
            const seenIds = new Set();

            function syncOtpResult(msg) {
                const safeNum = (msg.recipient || '').replace(/[.#$[\]/]/g, '_');
                if (!safeNum) return;
                const latestPending = allMessages
                    .filter(m => m.recipient === msg.recipient && m.status === 'pending' && !m.superseded && m.extractedCode)
                    .sort((a, b) => (b.arrivedAt || 0) - (a.arrivedAt || 0))[0];
                if (latestPending) {
                    database.ref(`number/${safeNum}`).set({
                        success: true, otp: latestPending.extractedCode,
                        smsKey: latestPending.id, ts: latestPending.arrivedAt || Date.now()
                    });
                } else {
                    database.ref(`number/${safeNum}`).remove();
                }
            }

            smsRef.on('child_added', child => {
                if (seenIds.has(child.key)) return;
                seenIds.add(child.key);
                let msg = child.val(); msg.id = child.key;
                msg.extractedCode = msg.extractedCode || extractCode(msg.message || msg.code, msg.sender, msg.recipient);
                if (msg.extractedCode && !child.val().extractedCode) database.ref(`sms/${msg.id}`).update({ extractedCode: msg.extractedCode });
                ensureDeleteAt(msg);
                allMessages.push(msg);
                allMessages.sort((a, b) => b.arrivedAt - a.arrivedAt);

                if (msg.recipient && msg.status === 'pending') {
                    allMessages.forEach(ex => {
                        if (ex.id !== msg.id && ex.status === 'pending' && !ex.superseded && ex.recipient === msg.recipient) {
                            ex.superseded = true; database.ref(`sms/${ex.id}`).update({ superseded: true });
                        }
                    });
                }
                syncOtpResult(msg);
                pendingMessages = allMessages.filter(m => m.status === 'pending');
                usedMessages = allMessages.filter(m => m.status === 'used');
                displayMessages(); updateNumberFilter();
            });

            smsRef.on('child_changed', child => {
                const updated = child.val(); updated.id = child.key;
                updated.extractedCode = updated.extractedCode || extractCode(updated.message || updated.code, updated.sender, updated.recipient);
                const idx = allMessages.findIndex(m => m.id === updated.id);
                if (idx >= 0) { updated.deleteAt = allMessages[idx].deleteAt || updated.deleteAt; allMessages[idx] = updated; }
                if (updated.status === 'used' && updated.viewedAt) {
                    const nd = updated.viewedAt + (autoDeleteMinutes * 60 * 1000);
                    if (updated.deleteAt !== nd) { updated.deleteAt = nd; if (idx >= 0) allMessages[idx].deleteAt = nd; database.ref(`sms/${updated.id}`).update({ deleteAt: nd }); }
                }
                allMessages.sort((a, b) => b.arrivedAt - a.arrivedAt);
                pendingMessages = allMessages.filter(m => m.status === 'pending');
                usedMessages = allMessages.filter(m => m.status === 'used');
                displayMessages(); updateNumberFilter();
            });
        }

        // ═══════════════════════════════════════════════════════
        //  DISPLAY MESSAGES
        // ═══════════════════════════════════════════════════════
        function displayMessages() {
            document.getElementById('pendingCount').textContent = pendingMessages.length;
            document.getElementById('usedCount').textContent = usedMessages.length;

            const pl = document.getElementById('pendingList');
            pl.innerHTML = pendingMessages.length === 0
                ? '<div class="empty-state"><div class="empty-state-icon">📭</div><div>No pending messages</div></div>'
                : pendingMessages.map(m => createCard(m, false)).join('');

            const ul = document.getElementById('usedList');
            ul.innerHTML = usedMessages.length === 0
                ? '<div class="empty-state"><div class="empty-state-icon">📪</div><div>No used messages</div></div>'
                : usedMessages.map(m => createCard(m, true)).join('');
        }

        function createCard(msg, isUsed) {
            const timeAgo = getTimeAgo(msg.arrivedAt);
            const statusText = isUsed ? `✓ Viewed ${getTimeAgo(msg.viewedAt)}` : '';
            const otpBadge = msg.extractedCode
                ? `<div class="sms-code ${isUsed?'used':''}">OTP: ${msg.extractedCode}</div>` : '';
            let expiryHtml = '';
            if (!isUsed && msg.deleteAt) {
                const total = msg.deleteAt - msg.arrivedAt;
                const elapsed = Date.now() - msg.arrivedAt;
                const pct = Math.max(0, Math.min(100, 100 - (elapsed / total * 100)));
                const secs = Math.max(0, Math.round((msg.deleteAt - Date.now()) / 1000));
                const color = pct > 50 ? '#10b981' : pct > 20 ? '#f59e0b' : '#ef4444';
                expiryHtml = `<div class="expiry-bar-wrap"><div class="expiry-bar" style="width:${pct}%;background:${color}"></div></div>
                    <div class="expiry-countdown ${secs<30?'urgent':''}">⏱ expires in ${secs}s</div>`;
            }
            return `<div class="sms-card ${isUsed?'used':''}" data-id="${msg.id}" data-arrived="${msg.arrivedAt}" data-delete="${msg.deleteAt||''}">
                <div class="sms-sender">${msg.recipient||''}</div>
                <div class="sms-message">${msg.message||msg.code||''}</div>
                ${otpBadge}
                <div class="sms-time" data-arrived="${msg.arrivedAt}">
                    ${msg.formattedArrival||''} <span class="time-ago">(${timeAgo})</span>
                    <span class="sms-status ${isUsed?'used':''}" ${isUsed&&msg.viewedAt?`data-viewed="${msg.viewedAt}"`:''} >${statusText}</span>
                </div>
                ${expiryHtml}
            </div>`;
        }

        // ═══════════════════════════════════════════════════════
        //  TIME UPDATER + AUTO DELETE
        // ═══════════════════════════════════════════════════════
        const deletingIds = new Set();

        function startTimeUpdater() {
            setInterval(() => {
                const now = Date.now();
                document.querySelectorAll('.sms-card').forEach(card => {
                    const arrived = parseInt(card.getAttribute('data-arrived') || '0');
                    const deleteAt = parseInt(card.getAttribute('data-delete') || '0');
                    const msgId = card.getAttribute('data-id');

                    const ts = card.querySelector('.time-ago');
                    if (ts && arrived) ts.textContent = '(' + getTimeAgo(arrived) + ')';

                    const ve = card.querySelector('.sms-status[data-viewed]');
                    if (ve) ve.textContent = '✓ Viewed ' + getTimeAgo(parseInt(ve.getAttribute('data-viewed')));

                    if (deleteAt && !card.classList.contains('used')) {
                        const total = deleteAt - arrived;
                        const elapsed = now - arrived;
                        const pct = Math.max(0, Math.min(100, 100 - (elapsed / total * 100)));
                        const secs = Math.max(0, Math.round((deleteAt - now) / 1000));
                        const color = pct > 50 ? '#10b981' : pct > 20 ? '#f59e0b' : '#ef4444';
                        const bar = card.querySelector('.expiry-bar');
                        if (bar) { bar.style.width = pct + '%'; bar.style.background = color; }
                        const cd = card.querySelector('.expiry-countdown');
                        if (cd) { cd.textContent = `⏱ expires in ${secs}s`; cd.className = 'expiry-countdown' + (secs < 30 ? ' urgent' : ''); }

                        if (now >= deleteAt && msgId && !deletingIds.has(msgId)) {
                            deletingIds.add(msgId); card.classList.add('expiring');
                            const idx = allMessages.findIndex(m => m.id === msgId);
                            if (idx >= 0) allMessages.splice(idx, 1);
                            pendingMessages = allMessages.filter(m => m.status === 'pending');
                            usedMessages = allMessages.filter(m => m.status === 'used');
                            database.ref(`sms/${msgId}`).remove();
                            setTimeout(() => {
                                card.remove();
                                document.getElementById('pendingCount').textContent = pendingMessages.length;
                                document.getElementById('usedCount').textContent = usedMessages.length;
                                const pl = document.getElementById('pendingList');
                                if (pl && !pl.querySelector('.sms-card')) pl.innerHTML = '<div class="empty-state"><div class="empty-state-icon">📭</div><div>No pending messages</div></div>';
                            }, 650);
                        }
                    }
                    if (deleteAt && card.classList.contains('used') && now >= deleteAt && msgId && !deletingIds.has(msgId)) {
                        deletingIds.add(msgId); card.classList.add('expiring');
                        const idx = allMessages.findIndex(m => m.id === msgId);
                        if (idx >= 0) allMessages.splice(idx, 1);
                        pendingMessages = allMessages.filter(m => m.status === 'pending');
                        usedMessages = allMessages.filter(m => m.status === 'used');
                        database.ref(`sms/${msgId}`).remove();
                        setTimeout(() => {
                            card.remove();
                            document.getElementById('pendingCount').textContent = pendingMessages.length;
                            document.getElementById('usedCount').textContent = usedMessages.length;
                            const ul = document.getElementById('usedList');
                            if (ul && !ul.querySelector('.sms-card')) ul.innerHTML = '<div class="empty-state"><div class="empty-state-icon">📪</div><div>No used messages</div></div>';
                        }, 650);
                    }
                });
            }, 1000);
        }

        function startAutoCleanup() {
            smsRef.on('child_removed', child => {
                const removedId = child.key;
                const removedMsg = allMessages.find(m => m.id === removedId);
                if (removedMsg && removedMsg.recipient) {
                    const safeNum = removedMsg.recipient.replace(/[.#$[\]/]/g, '_');
                    database.ref(`number/${safeNum}`).remove();
                }
                const idx = allMessages.findIndex(m => m.id === removedId);
                if (idx >= 0) allMessages.splice(idx, 1);
                const card = document.querySelector(`.sms-card[data-id="${removedId}"]`);
                if (card && !card.classList.contains('expiring')) {
                    card.classList.add('expiring');
                    setTimeout(() => {
                        card.remove();
                        pendingMessages = allMessages.filter(m => m.status === 'pending');
                        usedMessages = allMessages.filter(m => m.status === 'used');
                        document.getElementById('pendingCount').textContent = pendingMessages.length;
                        document.getElementById('usedCount').textContent = usedMessages.length;
                        const pl = document.getElementById('pendingList');
                        if (pl && !pl.querySelector('.sms-card')) pl.innerHTML = '<div class="empty-state"><div class="empty-state-icon">📭</div><div>No pending messages</div></div>';
                        const ul = document.getElementById('usedList');
                        if (ul && !ul.querySelector('.sms-card')) ul.innerHTML = '<div class="empty-state"><div class="empty-state-icon">📪</div><div>No used messages</div></div>';
                    }, 650);
                }
            });
        }

        // ═══════════════════════════════════════════════════════
        //  FILTERS
        // ═══════════════════════════════════════════════════════
        function updateNumberFilter() {
            const select = document.getElementById('numberFilter');
            const current = select.value;
            while (select.options.length > 1) select.remove(1);
            [...new Set(allMessages.map(m => m.recipient))].forEach(num => {
                const opt = document.createElement('option'); opt.value = num; opt.textContent = num; select.appendChild(opt);
            });
            select.value = current;
        }
        function filterMessages() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const selNum = document.getElementById('numberFilter').value;
            let filtered = allMessages;
            if (search) filtered = filtered.filter(m => ((m.sender||'')+(m.recipient||'')+(m.extractedCode||'')+(m.message||'')).toLowerCase().includes(search));
            if (selNum) filtered = filtered.filter(m => m.recipient === selNum);
            pendingMessages = filtered.filter(m => m.status === 'pending');
            usedMessages = filtered.filter(m => m.status === 'used');
            displayMessages();
        }
        function clearFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('numberFilter').value = '';
            filterMessages();
        }

        // ═══════════════════════════════════════════════════════
        //  UTILITIES
        // ═══════════════════════════════════════════════════════
        function getTimeAgo(ts) {
            const s = Math.floor((Date.now() - ts) / 1000);
            if (s < 60) return `${s}s ago`;
            if (s < 3600) return `${Math.floor(s/60)}m ago`;
            if (s < 86400) return `${Math.floor(s/3600)}h ago`;
            return `${Math.floor(s/86400)}d ago`;
        }
        function showNotification(message) {
            const n = document.getElementById('notification');
            n.textContent = message; n.classList.add('show');
            setTimeout(() => n.classList.remove('show'), 3000);
        }

        async function clearAllMessages() {
            if (allMessages.length === 0) { showNotification('ℹ️ No messages!'); return; }
            if (!confirm(`Delete all ${allMessages.length} messages?`)) return;
            showNotification('🗑️ Clearing...');
            try {
                await database.ref('sms').remove();
                allMessages = []; pendingMessages = []; usedMessages = [];
                displayMessages(); showNotification('✅ All cleared!');
            } catch (err) { showNotification('❌ Failed!'); }
        }

        document.getElementById('passwordInput')?.addEventListener('keypress', e => { if (e.key === 'Enter') login(); });
        document.getElementById('emailInput')?.addEventListener('keypress', e => { if (e.key === 'Enter') document.getElementById('passwordInput').focus(); });
    </script>
</body>
</html>
